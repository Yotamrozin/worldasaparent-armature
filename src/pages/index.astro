---
// Server-rendered so it can read the draft-mode cookie per request (visual
// editing). This page bypasses the template's generic Layout/Navbar — the
// ported App component below has its own bespoke navbar (anchor-scroll
// within this single-page design), so using the generic one would render two.
//
// Uses LiveHomepage (not @sanity/astro's <VisualEditing>) so edits in
// Presentation stream in live instead of requiring a full page reload — see
// src/site/LiveHomepage.tsx for why.
export const prerender = false;

import '../styles/global.css';
import { loadQuery } from '../lib/sanity/loadQuery';
import { getPerspectiveCookie } from '../lib/sanity/draftMode';
import { urlFor } from '../lib/sanity/image';
import LiveHomepage from '../site/LiveHomepage';
import { resolveHomepageProps, HOMEPAGE_QUERY, type HomepageDoc } from '../site/resolveHomepageProps';

const perspective = getPerspectiveCookie(Astro.cookies);
const draftMode = Boolean(perspective);

const { data: homepage } = await loadQuery<HomepageDoc | null>({
  query: HOMEPAGE_QUERY,
  perspective,
});

const props = resolveHomepageProps(homepage, (image, opts) => {
  let builder = urlFor(image).width(opts.width).auto('format');
  if (opts.height) builder = builder.height(opts.height).fit('crop');
  return builder.url();
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{props.hero.title}</title>
  </head>
  <body>
    {
      homepage ? (
        <LiveHomepage client:load initialProps={props} enabled={draftMode} />
      ) : (
        <main class="empty">
          <h1>No homepage content yet</h1>
          <p>
            Open the <a href="/admin">Studio</a>, fill in the Homepage document, and publish.
          </p>
        </main>
      )
    }
  </body>
</html>

<style>
  .empty {
    max-width: 40rem;
    margin: 6rem auto;
    padding: 0 1.5rem;
    text-align: center;
    color: #555;
    font-family: system-ui, sans-serif;
  }
</style>
