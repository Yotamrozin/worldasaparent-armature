---
interface NavLink {
  label: string;
  href: string;
}

interface Props {
  siteTitle?: string;
  logoUrl?: string | null;
  logoAlt?: string;
  links: NavLink[];
}

const { siteTitle, logoUrl, logoAlt, links } = Astro.props;
---

<header class="navbar">
  <a class="navbar__brand" href="/">
    {logoUrl ? <img class="navbar__logo" src={logoUrl} alt={logoAlt ?? siteTitle ?? ''} /> : siteTitle || 'Armature'}
  </a>
  {
    links.length > 0 && (
      <nav class="navbar__nav" aria-label="Primary">
        <ul class="navbar__list">
          {links.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }
</header>

<style>
  .navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    max-width: 64rem;
    margin-inline: auto;
  }
  .navbar__brand {
    font-weight: 700;
    font-size: 1.1rem;
    color: inherit;
    text-decoration: none;
  }
  .navbar__logo {
    display: block;
    height: 2rem;
    width: auto;
  }
  .navbar__list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .navbar__list a {
    color: inherit;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .navbar__list a:hover {
    text-decoration: underline;
  }
</style>
