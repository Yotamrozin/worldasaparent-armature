# Sanity project credentials. Copy to .env and fill in real values.
# Find these at https://sanity.io/manage (or run: npx sanity projects list)
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# Server-only Viewer token for draft mode / visual editing.
# No PUBLIC_ prefix — it must never be exposed to the browser.
# Create at https://sanity.io/manage -> your project -> API -> Tokens (Viewer role).
SANITY_API_READ_TOKEN=your-viewer-token
